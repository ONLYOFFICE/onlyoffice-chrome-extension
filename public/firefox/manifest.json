{
  "manifest_version": 3,
  "name": "ONLYOFFICE DocSpace",
  "version": "1.0.0",
  "description": "Access and manage your ONLYOFFICE DocSpace files directly from Firefox",
  "permissions": [
    "storage",
    "activeTab",
    "identity",
    "scripting",
    "downloads",
    "tabs",
    "webRequest",
    "webRequestBlocking",
    "cookies",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "https://oauth.onlyoffice.com/*",
    "https://*.onlyoffice.com/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
